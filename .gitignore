# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock files are committed for root configs; ignore in the module itself
# (uncomment if you do not want to track them here)
# .terraform.lock.hcl

# CLI config
.terraformrc
terraform.rc
